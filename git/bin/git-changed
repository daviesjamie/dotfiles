#!/usr/bin/env bash
set -euo pipefail

USAGE="
usage: $(basename "$0") [old_ref] [new_ref]

Lists the files that have changed between two git references.

arguments:
  [old_ref]  The git ref to start the diff at. Defaults to the origin's HEAD.
  [new_ref]  The git ref to end the diff at. Defaults to HEAD.
"

old_ref=${1:-}
if [[ -z "$old_ref" ]]; then
  old_ref=$(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@')
fi

new_ref=${2:-}
if [[ -z "$new_ref" ]]; then
  new_ref="HEAD"
fi

merge_base=$(git merge-base "$old_ref" "$new_ref")
git diff --name-only "$merge_base" "$new_ref" | sort
