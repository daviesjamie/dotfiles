#!/usr/bin/env bash
set -e

MERGE_BASE=$1
BRANCH=$2

if [[ -z "$MERGE_BASE" ]]; then
  MERGE_BASE=$(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@')
fi

if [[ -z "$BRANCH" ]]; then
  BRANCH="HEAD"
fi

REF=$(git merge-base "$MERGE_BASE" "$BRANCH")
git diff --name-only "$REF" | sort
