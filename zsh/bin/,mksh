#!/usr/bin/env bash
set -euo pipefail

USAGE="
usage: $(basename "$0") <name> [dir]

Creates a new executable shell script from a template.

arguments:
  <name>    The name of the script
  [dir]     An optional place to create the script.
            Defaults to ~/.dotfiles/zsh/bin. If dir is in ~/.dotfiles,
            automatically reruns 'stow' to generate symlink.
"

name=${1:-}
if [ -z "$name" ]; then
  echo >&2 "<name> is required!"
  echo "$USAGE"
  exit 1
fi

dir=${2:-"$HOME/.dotfiles/zsh/bin"}
script_name="$dir/$name"

if [ -f "$script_name" ]; then
  echo >&2 "$script_name already exists!"
  exit 1
fi

echo "Creating script $script_name"

cat >"$script_name" <<EOF
#!/usr/bin/env bash
set -euo pipefail

USAGE="
usage: \$(basename "\$0") <foo> [bar]

Does something fun.

arguments:
  <foo>   Description of foo
  [bar]   Description of bar
"

foo="\${1:-}"
if [ -z "\$foo" ]; then
  echo >&2 "<foo> is required!"
  echo "\$USAGE"
  exit
fi

bar=\${2:-"default_bar"}

echo "\$foo" "\$bar"
EOF

chmod +x "$script_name"

# If we're editing within ~/.dotfiles, link the file into place with `stow`
dotfiles_regex="^$HOME/.dotfiles/([^/]+)"
if [[ $script_name =~ $dotfiles_regex ]] && type stow &>/dev/null; then
  stow_package="${BASH_REMATCH[1]}"
  echo "Restowing $stow_package"
  stow -d ~/.dotfiles -R "$stow_package"
fi

${VISUAL:-${EDITOR:-vi}} "${script_name}"
